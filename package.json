{
  "name": "agent-translator",
  "version": "0.3.2",
  "description": "Local-first localization CLI for coding-agent translation workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MikeChongCan/agent-translator"
  },
  "type": "module",
  "bin": {
    "agent-translator": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "rm -rf dist && bun build src/cli.ts src/index.ts src/config.ts --target=node --outdir=dist && chmod +x dist/cli.js && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "files": [
    "dist",
    "docs/formats",
    "docs/agent-prompts.md",
    "docs/publishing.md",
    "skills",
    "README.md",
    "VISION.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "keywords": [
    "i18n",
    "l10n",
    "translation",
    "localization",
    "cli",
    "xcstrings",
    "gettext",
    "android",
    "fastlane"
  ],
  "author": "Mike Chong",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.3.2",
    "gettext-parser": "^8.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/gettext-parser": "^4.0.4",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
